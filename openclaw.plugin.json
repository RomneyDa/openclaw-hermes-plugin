{
  "id": "hermes-plugin",
  "name": "Hermes Plugin Bridge",
  "description": "Installs and calls Hermes Agent Python plugins from OpenClaw.",
  "version": "0.1.0",
  "activation": {
    "onStartup": true
  },
  "contracts": {
    "tools": [
      "hermes_plugins_list",
      "hermes_tool_call",
      "hermes_plugin_install"
    ]
  },
  "toolMetadata": {
    "hermes_plugins_list": {
      "optional": true
    },
    "hermes_tool_call": {
      "optional": true
    },
    "hermes_plugin_install": {
      "optional": true
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "installDir": {
        "type": "string",
        "description": "Directory containing installed Hermes plugins. Defaults to ~/.openclaw/hermes-plugins."
      },
      "python": {
        "type": "string",
        "description": "Python executable used to load Hermes plugins.",
        "default": "python3"
      },
      "timeoutMs": {
        "type": "integer",
        "minimum": 1000,
        "default": 120000
      },
      "env": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        },
        "description": "Extra environment variables passed to Hermes plugin calls."
      }
    }
  }
}
