{
  "name": "openclaw-hermes-plugin",
  "version": "0.1.0",
  "description": "OpenClaw bridge for Hermes Agent Python plugins",
  "license": "MIT",
  "type": "module",
  "main": "dist/bin.js",
  "bin": {
    "openclaw-hermes-plugin": "./dist/bin.js"
  },
  "files": [
    "openclaw.plugin.json",
    "mcp/",
    "skills/",
    "dist/",
    "python/",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/romneyda/openclaw-hermes-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/romneyda/openclaw-hermes-plugin/issues"
  },
  "homepage": "https://github.com/romneyda/openclaw-hermes-plugin#readme",
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "hermes",
    "hermes-agent",
    "plugins"
  ],
  "engines": {
    "node": ">=22.19"
  },
  "openclaw": {
    "extensions": ["./src/index.ts"],
    "runtimeExtensions": ["./dist/index.js"]
  },
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc -p tsconfig.json && esbuild src/bin.ts --bundle --platform=node --format=esm --packages=bundle --banner:js='#!/usr/bin/env node' --outfile=dist/bin.js",
    "test": "vitest run",
    "check": "npm run build && npm test",
    "pack:local": "npm run build && npm pack"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.9.0",
    "vitest": "^4.1.4"
  }
}
